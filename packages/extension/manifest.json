{
  "manifest_version": 3,
  "name": "Temu Product Collector",
  "version": "1.0.0",
  "description": "Collect Temu product data for batch listing tool",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.temu.com/*", "https://seller.temu.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.temu.com/*"],
      "js": ["src/content/scraper.js", "src/content/temu-product.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Temu Collector"
  }
}
