{
  "manifest_version": 3,
  "name": "Temu 产品采集",
  "version": "1.0.0",
  "description": "一键采集 Temu 产品数据，配合铺货工具使用",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.temu.com/*", "https://seller.temu.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.temu.com/*"],
      "js": ["src/content/temu-product.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Temu 采集工具"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
