{
  "name": "@temu-lister/electron",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron dist/main.js",
    "build": "tsc",
    "start": "electron dist/main.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "playwright-core": "^1.49.0",
    "sharp": "^0.33.0",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@temu-lister/shared": "workspace:*",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "electron": "^33.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.temu.lister",
    "productName": "Temu Lister",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web/dist"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "compression": "normal",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  }
}
